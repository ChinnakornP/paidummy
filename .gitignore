paidummy/.packages
paidummy/.pub-cache/
paidummy/.pub/
paidummy/build/
paidummy/.flutter-plugins
paidummy/.flutter-plugins-dependencies
paidummy/.fvm/                       # FVM-managed SDK pin

# iOS / macOS Xcode scaffolds
paidummy/ios/Pods/
paidummy/ios/.symlinks/
paidummy/ios/Flutter/Flutter.framework
paidummy/ios/Flutter/Flutter.podspec
paidummy/ios/Flutter/Generated.xcconfig
