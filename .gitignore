# =====================================================================
# Go server  (./server)
# =====================================================================
server/server
server/*.test
server/*.out
server/coverage.txt
server/coverage.html
server/tmp/                # air / live-reload working dir
server/dist/
server/bin/

# Local secrets / config
server/.env
server/.env.*
!server/.env.example

# Go build & test caches that occasionally leak into the tree
*.exe
*.dll
*.so
*.dylib
*.test
*.out
*.prof

